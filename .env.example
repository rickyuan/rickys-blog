# ==========================================
# Astro site (used by Cloudflare Pages SSR)
# ==========================================
# Anon key is safe to expose to browsers — NEVER put service_role here.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ==========================================
# Weekly digest cron (used by Railway + local `npx tsx scripts/weekly-digest.ts`)
# ==========================================
# Service role key bypasses RLS — keep secret, never commit, never put in browser-facing code.
# In production this lives only in Railway Variables.
SUPABASE_SERVICE_KEY=eyJ...

# Anthropic API key for Haiku (classify) + Sonnet (synthesize)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — Telegram failure alerts
# Get from @BotFather; chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
