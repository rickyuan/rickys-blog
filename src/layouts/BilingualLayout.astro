---
import '@styles/editorial.css';

interface Props {
  title: string;
  title_cn?: string;
  description?: string;
  pubDate?: string;
  category?: string;
}

const { title, title_cn, description = "Ricky's Space — Dossier", pubDate, category } = Astro.props;
const formattedDate = pubDate ? new Date(pubDate).toISOString().slice(0, 10) : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400..900;1,400..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=JetBrains+Mono:wght@400;700&family=Noto+Serif+SC:wght@300;400;500;700;900&family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap"
    rel="stylesheet"
  />
  <style>
    /* ── Bilingual-specific overrides ── */
    .bilingual-header {
      max-width: 800px;
      margin: 4rem auto 2rem;
      padding: 0 2rem;
      border-bottom: 2px solid #1a1a1a;
      padding-bottom: 2rem;
    }
    .bilingual-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 0.75rem;
    }
    .bilingual-title-en {
      font-family: 'Bodoni Moda', 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 0.4rem;
      color: #1a1a1a;
    }
    .bilingual-title-cn {
      font-family: 'Noto Serif SC', serif;
      font-size: clamp(1.1rem, 3vw, 1.6rem);
      font-weight: 400;
      color: #555;
      margin: 0 0 1.25rem;
    }
    .bilingual-meta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      color: #888;
    }
    .bilingual-meta .tag {
      background: #1a1a1a;
      color: #f4ecd8;
      padding: 0.15rem 0.5rem;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
    }

    /* ── Language toggle ── */
    .lang-toggle-bar {
      position: sticky;
      top: 0;
      z-index: 50;
      background: #f4ecd8;
      border-bottom: 1px solid #ccc;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 0.4rem 2rem;
      gap: 0.5rem;
    }
    .lang-toggle-bar span {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem;
      color: #888;
      letter-spacing: 0.1em;
    }
    .lang-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      padding: 0.2rem 0.6rem;
      border: 1px solid #ccc;
      background: transparent;
      cursor: pointer;
      letter-spacing: 0.08em;
      color: #555;
      transition: background 0.15s, color 0.15s;
    }
    .lang-btn.active {
      background: #1a1a1a;
      color: #f4ecd8;
      border-color: #1a1a1a;
    }

    /* ── Content area ── */
    .bilingual-body {
      max-width: 800px;
      margin: 0 auto;
      padding: 2.5rem 2rem 6rem;
    }

    /* Desktop side-by-side (≥900px) */
    @media (min-width: 900px) {
      .bilingual-body {
        max-width: 1200px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 3rem;
        align-items: start;
      }
      .bilingual-body .bilingual-en,
      .bilingual-body .bilingual-cn {
        padding-top: 0;
      }
      /* In desktop both-mode, hide toggle; show both columns */
      body.mode-both .lang-toggle-bar { display: none; }
      body.mode-en .bilingual-cn { display: none; }
      body.mode-cn .bilingual-en { display: none; }
    }

    /* Mobile / single-column */
    @media (max-width: 899px) {
      body.mode-en .bilingual-cn { display: none; }
      body.mode-cn .bilingual-en { display: none; }
      body.mode-both .bilingual-cn { margin-top: 2rem; border-top: 1px dashed #ccc; padding-top: 2rem; }
    }

    /* ── EN block typography ── */
    .bilingual-en {
      font-family: 'Bodoni Moda', 'Playfair Display', serif;
      font-size: 1.05rem;
      line-height: 1.8;
      color: #1a1a1a;
    }
    .bilingual-en h2 {
      font-size: 1.4rem;
      font-weight: 700;
      margin: 2.5rem 0 0.75rem;
      border-bottom: 1px solid #1a1a1a;
      padding-bottom: 0.3rem;
    }
    .bilingual-en h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 1.75rem 0 0.5rem;
    }
    .bilingual-en p { margin: 0 0 1.1rem; }
    .bilingual-en strong { font-weight: 700; }
    .bilingual-en a { color: #8b1a1a; text-decoration: underline; }
    .bilingual-en ul, .bilingual-en ol { margin: 0.5rem 0 1rem 1.5rem; }
    .bilingual-en li { margin-bottom: 0.4rem; }

    /* ── CN block typography ── */
    .bilingual-cn {
      font-family: 'Noto Serif SC', 'Noto Sans SC', serif;
      font-size: 1rem;
      line-height: 1.9;
      color: #2a2a2a;
    }
    .bilingual-cn h2 {
      font-size: 1.25rem;
      font-weight: 700;
      margin: 2.5rem 0 0.75rem;
      border-bottom: 1px solid #888;
      padding-bottom: 0.3rem;
      color: #555;
    }
    .bilingual-cn h3 {
      font-size: 1rem;
      font-weight: 600;
      margin: 1.75rem 0 0.5rem;
      color: #555;
    }
    .bilingual-cn p { margin: 0 0 1.1rem; }
    .bilingual-cn strong { font-weight: 700; }
    .bilingual-cn a { color: #8b1a1a; text-decoration: underline; }
    .bilingual-cn ul, .bilingual-cn ol { margin: 0.5rem 0 1rem 1.5rem; }
    .bilingual-cn li { margin-bottom: 0.4rem; }

    /* ── Nav back ── */
    .back-nav {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: #888;
      text-decoration: none;
      padding: 1rem 2rem;
      display: inline-block;
    }
    .back-nav:hover { color: #1a1a1a; }
  </style>
</head>
<body class="mode-both">

  <a class="back-nav" href="/">← rickys.space</a>

  <header class="bilingual-header">
    <div class="bilingual-eyebrow">
      {category && <span class="tag">{category}</span>}
      {formattedDate && <span style="margin-left:0.5rem">{formattedDate}</span>}
    </div>
    <h1 class="bilingual-title-en">{title}</h1>
    {title_cn && <p class="bilingual-title-cn">{title_cn}</p>}
    <div class="bilingual-meta">
      <span>Ricky Yuan · Singapore</span>
    </div>
  </header>

  <div class="lang-toggle-bar">
    <span>LANG:</span>
    <button class="lang-btn active" data-mode="both">EN + 中</button>
    <button class="lang-btn" data-mode="en">EN only</button>
    <button class="lang-btn" data-mode="cn">中文</button>
  </div>

  <div class="bilingual-body">
    <slot />
  </div>

  <footer style="text-align:center;padding:2rem;font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:#aaa;border-top:1px solid #ddd;">
    © 2026 Ricky's Space
  </footer>

</body>

<script>
  const body = document.body;
  const btns = document.querySelectorAll<HTMLButtonElement>('.lang-btn');
  const STORAGE_KEY = 'ricky-lang-mode';

  const saved = localStorage.getItem(STORAGE_KEY) ?? 'both';
  setMode(saved);

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode!;
      setMode(mode);
      localStorage.setItem(STORAGE_KEY, mode);
    });
  });

  function setMode(mode: string) {
    body.className = `mode-${mode}`;
    btns.forEach((b) => b.classList.toggle('active', b.dataset.mode === mode));
  }
</script>
</html>
