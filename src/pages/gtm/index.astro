---
import TelexLayout from '@layouts/TelexLayout.astro';
import { supabasePublic, type Signal } from '@lib/supabase';

export const prerender = false;

const SIGNALS_PER_DAY = 10;

const { data: signals } = await supabasePublic
  .from('signals')
  .select('id, title, company_name, country, signal_type, icp_score, entry_point, enrichment, url, published_at, created_at, status')
  .not('status', 'in', '("watch","ignore")')
  .order('created_at', { ascending: false })
  .limit(500)
  .returns<Signal[]>();

const typeLabel: Record<string, string> = {
  competitor_blog: 'Competitor',
  product_launch: 'Launch',
  funding_round: 'Funding',
  hiring_signal: 'Hiring',
  regulation_update: 'Regulation',
  partnership: 'Partnership',
  expansion: 'Expansion',
  other: 'Other',
};

function scoreClass(score: number | null) {
  if (score === null) return '';
  if (score >= 80) return 'tx-gtm-score--high';
  if (score >= 65) return 'tx-gtm-score--mid';
  return 'tx-gtm-score--low';
}

const grouped = new Map<string, Signal[]>();
if (signals) {
  for (const s of signals) {
    const date = new Date(s.created_at).toISOString().slice(0, 10);
    if (!grouped.has(date)) grouped.set(date, []);
    grouped.get(date)!.push(s);
  }
  for (const [, items] of grouped) {
    items.sort((a, b) => (b.icp_score ?? -1) - (a.icp_score ?? -1));
  }
}
---
<TelexLayout title="GTM Intelligence · Ricky's Space" section="gtm" noindex={true}>
  <header class="tx-issue-header">
    <div class="tx-issue-eyebrow">Intelligence Feed</div>
    <h1 class="tx-issue-title">GTM Signals</h1>
    <div class="tx-curators-note">
      AI-scored market signals — competitor moves, funding rounds,
      partnerships, and expansion plays. Top {SIGNALS_PER_DAY} per day by ICP score.
    </div>
  </header>

  {grouped.size > 0 ? (
    <div class="tx-gtm-groups">
      {[...grouped.entries()].map(([date, items]) => (
        <section class="tx-gtm-group">
          <h2 class="tx-gtm-date-header">
            <a href={`/gtm/${date}`}>{date}</a>
            <span class="tx-gtm-date-count">{items.length} total · top {Math.min(SIGNALS_PER_DAY, items.length)} shown</span>
          </h2>
          <div class="tx-gtm-cards">
            {items.slice(0, SIGNALS_PER_DAY).map((s) => (
              <a class="tx-gtm-card" href={`/gtm/${s.id}`}>
                <div class="tx-gtm-card-head">
                  <span class={`tx-gtm-card-score ${scoreClass(s.icp_score)}`}>
                    {s.icp_score !== null ? Math.round(s.icp_score) : '—'}
                  </span>
                  <span class="tx-gtm-card-company">{s.company_name ?? 'Unknown'}</span>
                  {s.country && <span class="tx-gtm-card-country">{s.country}</span>}
                  {s.enrichment?.industry && (
                    <span class="tx-gtm-card-industry">{s.enrichment.industry}</span>
                  )}
                  {s.enrichment?.competitor_displaced && (
                    <span class="tx-gtm-card-competitor">vs {s.enrichment.competitor_displaced}</span>
                  )}
                </div>

                {s.enrichment?.reasoning && (
                  <p class="tx-gtm-card-reasoning">{s.enrichment.reasoning}</p>
                )}

                {s.entry_point && (
                  <p class="tx-gtm-card-entry">→ {s.entry_point}</p>
                )}

                <div class="tx-gtm-card-foot">
                  <span class="tx-gtm-badge">{typeLabel[s.signal_type] ?? s.signal_type}</span>
                  {!s.enrichment?.reasoning && (
                    <span class="tx-gtm-card-title">{s.title}</span>
                  )}
                  {s.url && (
                    <span class="tx-gtm-card-source">
                      {new URL(s.url).hostname.replace('www.', '')}
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  ) : (
    <p style="color: var(--tx-ink-muted); margin-top: 32px;">
      No signals yet — check back after the next collector run.
    </p>
  )}
</TelexLayout>
